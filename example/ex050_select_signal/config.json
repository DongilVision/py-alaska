{
  "app_info": {
    "name": "selective_signal_example",
    "id": "node-selective-001",
    "version": "1.0.0"
  },
  "platform_config": {
    "_monitor": {
      "port": 7000,
      "exit_hook": true
    }
  },
  "task_config": {
