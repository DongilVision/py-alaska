      "interval": 0.5
    },
    "worker_a/WorkerTask": {
      "@import": "example.ex050_select_signal.tasks",
      "job_type": "a"
    },
    "worker_b/WorkerTask": {
      "@import": "example.ex050_select_signal.tasks",
      "job_type": "b"
    },
    "worker_c/WorkerTask": {
      "@import": "example.ex050_select_signal.tasks",
      "job_type": "c"
    },
    "worker_d/WorkerTask": {
      "@import": "example.ex050_select_signal.tasks",
      "job_type": "d"
    },
    "dest/DestTask": {
      "@import": "example.ex050_select_signal.dest_ui"
    }
  }
}
